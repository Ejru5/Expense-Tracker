rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from an authenticated user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is the requesting user a member of this household?
    function isMember(householdId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    // Households — readable by authenticated users (for invite lookup), writable/updateable by members or joining user
    match /households/{householdId} {
      allow read: if isAuth();
      allow create: if isAuth();  // any auth user can create a household
      allow update: if isMember(householdId) || (
        isAuth() &&
        // Allow joining if adding oneself as a member
        request.resource.data.members.size() == resource.data.members.size() + 1 &&
        request.auth.uid in request.resource.data.members &&
        // Limit to a max of 2 members
        request.resource.data.members.size() <= 2
      );
      allow delete: if false;     // never delete households

      // All sub-collections are household-scoped
      match /transactions/{txId} {
        allow read, write: if isMember(householdId);
      }

      match /cards/{cardId} {
        allow read, write: if isMember(householdId);
      }

      match /categories/{catId} {
        allow read, write: if isMember(householdId);
      }

      match /budgets/{budgetId} {
        allow read, write: if isMember(householdId);
      }

      match /recurringBills/{billId} {
        allow read, write: if isMember(householdId);
      }

      match /savingsGoals/{goalId} {
        allow read, write: if isMember(householdId);
      }

      match /splits/{splitId} {
        allow read, write: if isMember(householdId);
      }

      match /templates/{templateId} {
        allow read, write: if isMember(householdId);
      }

      match /categoryOverrides/{overrideId} {
        allow read, write: if isMember(householdId);
      }
    }
  }
}
